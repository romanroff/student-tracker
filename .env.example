# Local Docker defaults. Never reuse these defaults on a public server.
APP_PORT=8080
POSTGRES_DB=student_tracker
POSTGRES_USER=student_tracker
POSTGRES_PASSWORD=change-me

# Local browser mode only. Set false on every public/university deployment.
DEV_AUTH_ENABLED=true
CORS_ORIGINS=http://localhost:8080

# Required for real Telegram Mini App authentication and the optional bot profile.
BOT_TOKEN=
WEBAPP_URL=https://student-tracker.example.edu
